generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./lelu.db"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("OFFICER")
// Roles: HEAD_OF_UNIT | SUPERVISOR | OFFICE_ADMINISTRATOR | OFFICER | ADMIN
  approved    Boolean   @default(false)
  deactivated Boolean   @default(false)
  cdrAccess   Boolean   @default(false)
  lastActive  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt DateTime @updatedAt
  cases     Case[]
  entries   JournalEntry[]
  cdrRequests CdrRequest[]
  internationalRequests InternationalRequest[]
  activityReports ActivityReport[]
  caseAssignments CaseAssignment[]
  notifications   Notification[]
}

model Case {
  id          String   @id @default(cuid())
  caseNumber  String   @unique
  title       String
  category    String
  status      String   @default("Active")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  closedAt    DateTime?
  closureReason String?
  officer     User?    @relation(fields: [officerId], references: [id])
  officerId   String?
  entries     JournalEntry[]
  cdrRequests CdrRequest[]
  internationalRequests InternationalRequest[]
  caseActivities CaseActivity[]
  caseAssignments CaseAssignment[]
}

model CaseAssignment {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedBy String
  assignedAt DateTime @default(now())
  status     String   @default("Pending") // "Pending" | "Accepted" | "Declined"

  @@unique([caseId, userId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  dayNumber Int
  content   String
  actions   String?
  createdAt DateTime @default(now())
  case      Case     @relation(fields: [caseId], references: [id])
  caseId    String
  author    User?    @relation(fields: [authorId], references: [id])
  authorId  String?
}

model CaseActivity {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  userId    String?
  userName  String
  action    String
  detail    String?
  createdAt DateTime @default(now())
}

model CdrRequest {
  id             String   @id @default(cuid())
  phoneNumber    String
  identifierType String   @default("Phone Number")
  telco          String?
  periodStart DateTime
  periodEnd   DateTime
  reason      String
  status      String   @default("Pending")
  requestedAt DateTime @default(now())
  receivedAt  DateTime?
  case        Case?    @relation(fields: [caseId], references: [id])
  caseId      String?
  officer     User?    @relation(fields: [officerId], references: [id])
  officerId   String?
  attachmentPath String?
  attachmentName String?
}

model InternationalRequest {
  id           String   @id @default(cuid())
  refNumber    String   @unique
  direction    String   // "Outgoing" or "Incoming"
  country      String
  agency       String
  subject      String
  details      String?
  status       String   @default("Pending")
  priority     String   @default("Medium")
  caseId       String?
  case         Case?    @relation(fields: [caseId], references: [id])
  officerId    String?
  officer      User?    @relation(fields: [officerId], references: [id])
  createdAt    DateTime @default(now())
  respondedAt  DateTime?
  attachmentPath String?
  attachmentName String?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  link      String?
  meta      String?  // JSON string — stores assignmentId, caseId, etc.
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityReport {
  id          String   @id @default(cuid())
  weekStart   DateTime
  weekEnd     DateTime
  summary     String
  casesWorked String?
  challenges  String?
  nextSteps   String?
  status      String   @default("Submitted")
  officerId   String?
  officer     User?    @relation(fields: [officerId], references: [id])
  createdAt   DateTime @default(now())
}