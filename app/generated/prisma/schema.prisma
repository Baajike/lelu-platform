generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./lelu.db"
}

model User {
  id                    String                 @id @default(cuid())
  name                  String
  email                 String                 @unique
  password              String
  role                  String                 @default("OFFICER")
  // Roles: HEAD_OF_UNIT | SUPERVISOR | OFFICE_ADMINISTRATOR | OFFICER | ADMIN
  approved              Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  cases                 Case[]
  entries               JournalEntry[]
  cdrRequests           CdrRequest[]
  internationalRequests InternationalRequest[]
  activityReports       ActivityReport[]
}

model Case {
  id                    String                 @id @default(cuid())
  caseNumber            String                 @unique
  title                 String
  category              String
  status                String                 @default("Active")
  priority              String                 @default("Medium")
  description           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  closedAt              DateTime?
  closureReason         String?
  officer               User                   @relation(fields: [officerId], references: [id])
  officerId             String
  entries               JournalEntry[]
  cdrRequests           CdrRequest[]
  internationalRequests InternationalRequest[]
  fraudEntities         FraudEntity[]
}

model JournalEntry {
  id        String   @id @default(cuid())
  dayNumber Int
  content   String
  actions   String?
  createdAt DateTime @default(now())
  case      Case     @relation(fields: [caseId], references: [id])
  caseId    String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
}

model CdrRequest {
  id             String    @id @default(cuid())
  phoneNumber    String
  telco          String
  periodStart    DateTime
  periodEnd      DateTime
  reason         String
  status         String    @default("Pending")
  requestedAt    DateTime  @default(now())
  receivedAt     DateTime?
  case           Case      @relation(fields: [caseId], references: [id])
  caseId         String
  officer        User      @relation(fields: [officerId], references: [id])
  officerId      String
  attachmentPath String?
  attachmentName String?
}

model FraudEntity {
  id        String   @id @default(cuid())
  type      String
  value     String
  category  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  caseId    String?
  case      Case?    @relation(fields: [caseId], references: [id])
}

model InternationalRequest {
  id             String    @id @default(cuid())
  refNumber      String    @unique
  direction      String // "Outgoing" or "Incoming"
  country        String
  agency         String
  subject        String
  details        String?
  status         String    @default("Pending")
  priority       String    @default("Medium")
  caseId         String?
  case           Case?     @relation(fields: [caseId], references: [id])
  officerId      String
  officer        User      @relation(fields: [officerId], references: [id])
  createdAt      DateTime  @default(now())
  respondedAt    DateTime?
  attachmentPath String?
  attachmentName String?
}

model ActivityReport {
  id          String   @id @default(cuid())
  weekStart   DateTime
  weekEnd     DateTime
  summary     String
  casesWorked String?
  challenges  String?
  nextSteps   String?
  status      String   @default("Submitted")
  officerId   String
  officer     User     @relation(fields: [officerId], references: [id])
  createdAt   DateTime @default(now())
}
